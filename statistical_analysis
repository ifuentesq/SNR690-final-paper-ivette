# -----------------------------------------------------------------------------
# Function: observed summaries
# Uncertainty computed directly in log10 space from raw observations
# This is the only fully coherent approach for log-scale plots
# NA returned for n=1 (undefined variance, not zero variance)
# -----------------------------------------------------------------------------

get_summary <- function(src) {
  data %>%
    filter(source == src) %>%
    group_by(concentration, time_days) %>%
    summarise(
      n        = n(),
      mean_log = mean(log10(fraction_remaining), na.rm = TRUE),
      sd_log   = ifelse(n() > 1,
                        sd(log10(fraction_remaining), na.rm = TRUE),
                        NA_real_),
      .groups  = "drop"
    ) %>%
    mutate(
      concentration = factor(as.character(concentration),
                             levels = c("500", "1000", "2000")),
      mean_frac     = 10^mean_log,
      frac_lo       = ifelse(!is.na(sd_log),
                             10^(mean_log - sd_log), NA_real_),
      frac_hi       = ifelse(!is.na(sd_log),
                             10^(mean_log + sd_log), NA_real_)
    )
}

# -----------------------------------------------------------------------------
# Function: fitted curves from global Model A
# Model integrity checks before computation
# Multiscale time sequence for early decay resolution
# d is log-rate: exp(d) is the actual rate multiplier (always positive)
# -----------------------------------------------------------------------------

get_curves <- function(src) {
  
  stopifnot(all(c("source", "concentration", "s", "d") %in% names(results_A)))
  
  bind_rows(lapply(c("500", "1000", "2000"), function(conc) {
    
    row <- dplyr::filter(results_A,
                         source        == src,
                         concentration == conc)
    
    # Model integrity checks
    stopifnot(nrow(row) == 1)
    stopifnot(is.numeric(row$d) && !is.na(row$d))
    stopifnot(is.numeric(row$s) && !is.na(row$s))
    stopifnot(row$s >= -0.01 && row$s <= 1)    # s should be valid fraction
    stopifnot(exp(row$d) > 0 && exp(row$d) < 100) # exp(d) must be stable
    
    # Multiscale time sequence — better resolution for early decay
    t_seq <- sort(unique(c(
      seq(0,   7,   by = 0.1),
      seq(7,   28,  by = 0.5),
      seq(28,  180, by = 1)
    )))
    
    tibble(
      concentration = conc,
      time_days     = t_seq,
      fitted        = row$s + (1 - row$s) * exp(-t_seq * exp(row$d))
    )
  })) %>%
    mutate(concentration = factor(concentration,
                                  levels = c("500", "1000", "2000")))
}

# -----------------------------------------------------------------------------
# Function: build one figure
# Faceted by concentration — no position_dodge on continuous time
# Error bars show SD in log10 space — explicitly stated in caption
# NA error bars omitted naturally by ggplot
# -----------------------------------------------------------------------------

make_fig <- function(curves_df, summary_df, title_text) {
  
  ggplot() +
    
    # Fitted decay curves from global Model A
    geom_line(data = curves_df,
              aes(x     = time_days,
                  y     = fitted,
                  color = concentration),
              linewidth = 1.2) +
    
    # SD bands — early time points only
    geom_errorbar(data  = summary_df %>% filter(time_days <= 28),
                  aes(x     = time_days,
                      ymin  = frac_lo,
                      ymax  = frac_hi,
                      color = concentration),
                  width = 0.8,
                  na.rm = TRUE) +
    
    # Observed geometric means
    geom_point(data  = summary_df,
               aes(x     = time_days,
                   y     = mean_frac,
                   shape = concentration,
                   color = concentration),
               size   = 3,
               stroke = 1.3) +
    
    # Legends now needed — no facet strips to label concentration
    scale_color_manual(values = conc_colors, labels = conc_labels) +
    scale_shape_manual(values = conc_shapes, labels = conc_labels) +
    
    scale_x_continuous(
      limits = c(0, 185),
      breaks = c(0, 1, 7, 14, 28, 90, 180)
    ) +
    
    scale_y_log10(
      limits = c(1e-4, 2),
      breaks = c(1e-3, 1e-2, 1e-1, 1e0),
      labels = scales::trans_format("log10", scales::math_format(10^.x))
    ) +
    
    labs(x       = "Time elapsed (days)",
         y       = "eDNA standard (fraction remaining)",
         color   = "Concentration",
         shape   = "Concentration",
         title   = title_text,
         caption = paste(
           "Curves: best-fit exponential decay model (Global Model A,",
           "Sirois & Buckley 2018).",
           "\nPoints: geometric means of observed fraction remaining (n=3).",
           "\nError bars: \u00b11 SD of log\u2081\u2080-transformed observations",
           "(variability, not confidence intervals).",
           "\nLoD for qPCR is below the plotted range and is not shown."
         )) +
    
    paper_theme
}

