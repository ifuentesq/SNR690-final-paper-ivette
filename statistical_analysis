# =============================================================================
# Step 3 — Fully factorial decay model
# Single unified NLS on all 189 rows
# Model equation from Sirois & Buckley (2018):
# fraction_remaining = s + (1 - s) * exp(-time_days * exp(d))
# =============================================================================

# Step 0 — prepare factors
data$source        <- factor(data$source,
                             levels = c("plasmid", "ground_tissue", "leaves"))
data$concentration <- factor(data$concentration,
                             levels = c(500, 1000, 2000))
data$group         <- interaction(data$source, data$concentration, sep = "_")
groups             <- levels(data$group)

# -----------------------------------------------------------------------------
# Null model — one d and s for ALL 189 rows
# -----------------------------------------------------------------------------

model_null <- nls(
  fraction_remaining ~ s + (1 - s) * exp(-time_days * exp(d)),
  data    = data,
  start   = list(d = 0.1, s = 0.001),
  control = nls.control(maxiter = 500)
)
summary(model_null)

# -----------------------------------------------------------------------------
# Model A — d and s vary by source x concentration (9 groups)
# Each group gets its own d and s — 18 parameters total
# -----------------------------------------------------------------------------

# Build formula dynamically
d_terms   <- paste0("d_", groups, " * (group == '", groups, "')",
                    collapse = " + ")
s_terms   <- paste0("s_", groups, " * (group == '", groups, "')",
                    collapse = " + ")

formula_A <- as.formula(paste0(
  "fraction_remaining ~ (", s_terms, ") + ",
  "(1 - (", s_terms, ")) * ",
  "exp(-time_days * exp(", d_terms, "))"
))

start_A <- c(
  setNames(rep(0.1,   length(groups)), paste0("d_", groups)),
  setNames(rep(0.001, length(groups)), paste0("s_", groups))
)

model_A <- nls(
  formula_A,
  data    = data,
  start   = start_A,
  control = nls.control(maxiter = 500)
)
summary(model_A)

# -----------------------------------------------------------------------------
# Model B — d shared globally, s varies by group
# 1 shared d + 9 group-specific s values — 10 parameters total
# -----------------------------------------------------------------------------

d_shared_global <- coef(model_null)["d"]

formula_B <- as.formula(paste0(
  "fraction_remaining ~ (", s_terms, ") + ",
  "(1 - (", s_terms, ")) * ",
  "exp(-time_days * exp(d_shared))"
))

start_B <- c(
  d_shared = as.numeric(d_shared_global),
  setNames(rep(0.001, length(groups)), paste0("s_", groups))
)

model_B <- nls(
  formula_B,
  data    = data,
  start   = start_B,
  control = nls.control(maxiter = 500)
)
summary(model_B)

# -----------------------------------------------------------------------------
# NLS ASSUMPTION CHECKS
# -----------------------------------------------------------------------------

# 1. Residuals vs Fitted
plot(fitted(model_A), residuals(model_A),
     xlab = "Fitted values",
     ylab = "Residuals",
     main = "Residuals vs Fitted — Model A")
abline(h = 0, lty = "dashed", col = "red")

# 2. Normality of residuals
shapiro.test(residuals(model_A))

# 3. Q-Q plot
qqnorm(residuals(model_A), main = "Normal Q-Q Plot — Model A residuals")
qqline(residuals(model_A), col = "red")

# 4. Scale-Location
plot(fitted(model_A), sqrt(abs(residuals(model_A))),
     xlab = "Fitted values",
     ylab = "sqrt(|Residuals|)",
     main = "Scale-Location — Model A")

# 5. Residuals by group
data$residuals_A <- residuals(model_A)
ggplot(data, aes(x = group, y = residuals_A, color = source)) +
  geom_boxplot() +
  geom_hline(yintercept = 0, linetype = "dashed") +
  labs(title = "Residuals by group — Model A",
       x     = "Group", y = "Residuals") +
  theme_bw() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

# 6. Residuals over time
ggplot(data, aes(x = time_days, y = residuals_A, color = source)) +
  geom_point() +
  geom_hline(yintercept = 0, linetype = "dashed") +
  geom_smooth(se = FALSE, linewidth = 0.8) +
  labs(title = "Residuals over time — Model A",
       x     = "Time (days)", y = "Residuals") +
  theme_bw()

# 7. Autocorrelation check
acf(residuals(model_A), main = "ACF of Model A residuals")


# -----------------------------------------------------------------------------
# Step 4 — Model selection by AIC and BIC
# NOW valid — all three models fit on same 189 rows
# -----------------------------------------------------------------------------

AIC(model_null, model_B, model_A)
BIC(model_null, model_B, model_A)

